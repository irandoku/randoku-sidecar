include README.md
include pyproject.toml
include CHANGELOG.md
recursive-include docs *.md
recursive-include examples *.ps1
recursive-include assets *.png
prune logs
prune dist
prune build
prune tmp-operator-test
prune __pycache__
prune .pytest_cache
global-exclude *.py[cod] *.log *.err.log .env .env.* *.pem
